# Copy to .env.local for local development (optional).
# Docker Compose reads HOST_PORT from the shell environment.

# SQLite database file (default: ./data/unihomelabdash.sqlite)
# DATABASE_PATH=./data/unihomelabdash.sqlite

# Docker Compose host port mapping (default: 3000)
# HOST_PORT=3000

# Dev only: allow a specific LAN IP for Next.js HMR (see next.config.ts)
# ALLOWED_DEV_ORIGIN=192.168.0.7
