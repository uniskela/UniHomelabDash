# Copy to .env.local for local development (optional).
# Docker Compose reads HOST_PORT and SESSION_SECRET from the shell or a .env file.

# SQLite database file (default: ./data/unihomelabdash.sqlite)
# DATABASE_PATH=./data/unihomelabdash.sqlite

# Docker Compose host port mapping (default: 3000)
# HOST_PORT=3000

# Required for signed session cookies (use a long random string in production)
# SESSION_SECRET=change-me-in-production

# Dev only: bypass authentication (never use in production)
# AUTH_DISABLED=false

# Set to true only when UniHomelabDash is served over HTTPS (reverse proxy with TLS)
# COOKIE_SECURE=false

# Dev only: allow a specific LAN IP for Next.js HMR (see next.config.ts)
# ALLOWED_DEV_ORIGIN=192.168.0.7
